// ShopTheBarber — Neon PostgreSQL schema (Prisma migrations)
// Column names match Drizzle `schema.ts` for zero-drift coexistence.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model users {
  id                    String   @id @default(uuid())
  clerk_user_id         String?  @unique
  email                 String   @unique
  full_name             String?
  role                  String?  @default("client")
  /// Immutable account type chosen at signup (client | solo_barber | shop | seller | company | blogger)
  account_type          String?
  account_type_locked_at String?
  avatar_url            String?
  phone                 String?
  /// SMS appointment reminders via Twilio
  sms_reminders_enabled Boolean? @default(true)
  email_reminders_enabled Boolean? @default(true)
  /// Smart SMS when client is usually due for another visit (habit-based rebook nudge)
  sms_rebook_nudges_enabled Boolean? @default(true)
  rebook_nudge_sent_at String?
  /// Unique share code e.g. STB-A1B2C3
  referral_code         String?  @unique
  referred_by_user_id   String?
  stripe_account_id     String?
  stripe_connect_status String?  @default("unconnected")
  /// Stripe Customer for saved cards & off-session charges
  stripe_customer_id    String?  @unique
  created_at            String?  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at            String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  shops_owned           shops[]  @relation("shop_owner")
  barbers               barbers[]
  bookings_as_client    bookings[] @relation("booking_client")
  loyalty_profiles      loyalty_profiles?
  messages_sent         messages[] @relation("msg_sender")
  messages_received     messages[] @relation("msg_receiver")
  notifications         notifications[]
  favorites             favorites[]
  cart_items            cart_items[]
  orders                orders[]
  applicant_profiles    applicant_profiles?
  applicant_credentials applicant_credentials[]
  job_applications      job_applications[]
  saved_jobs            saved_jobs[]
  wishlist_items        wishlist_items[]
  wallet_accounts       wallet_accounts?
  wallet_transactions   wallet_transactions[]
  referrals_made        referrals[] @relation("referrer")
  referrals_received    referrals[] @relation("referred")
  referred_by           users?  @relation("user_referrals", fields: [referred_by_user_id], references: [id])
  users_referred        users[] @relation("user_referrals")
  gift_cards_purchased  gift_cards[]
  articles_authored     articles[] @relation("article_author")
  articles_reviewed     articles[] @relation("article_reviewer")
  reviews_written       reviews[]  @relation("review_author")
  products_created      products[] @relation("product_creator")
  products_reviewed     products[] @relation("product_reviewer")
  inspiration_posts     inspiration_posts[]
  shop_members          shop_members[]
  shop_expenses_created shop_expenses[]
  jobs_created          jobs[]
  jobs_reviewed         jobs[] @relation("job_reviewer")
  interviews_created    interview_schedules[]
  tips_sent             booking_tips[] @relation("tip_client")
  tips_received         booking_tips[] @relation("tip_recipient")
  saved_addresses       saved_addresses[]
  support_tickets       support_tickets[] @relation("support_requester")
  support_assigned        support_tickets[] @relation("support_assignee")
  draw_entries          draw_entries[]
  draw_winner_claims    draw_winner_claims[]
  draws_won             weekly_draws[] @relation("draw_winner")
  events_created        platform_events[] @relation("event_creator")
  event_registrations   event_registrations[]
  privacy_audits        privacy_audits[]
  provider_fee_wallets  provider_fee_wallets[]
  provider_fee_transactions provider_fee_transactions[]
  language_programs_created language_programs[] @relation("language_program_creator")
  language_program_waitlist language_program_waitlist[]
  fixed_fee_plans           provider_fixed_fee_plans[]
  client_payment_methods    client_payment_methods[]
  product_analytics_events  product_analytics_events[]
  marketplace_reservations marketplace_reservations[]
  reputation_events     reputation_events[]
  seller_profile        seller_profiles?
  company_account       company_accounts?
  author_profile        author_profiles?
  ad_credit_wallets     ad_credit_wallets?
  dispute_appeals       dispute_appeals[]
  financing_applications financing_applications[]
  /// Phase 2 — client reputation & reliability
  reputation_score      Int?     @default(0)
  reputation_level      String?  @default("new")
  reliability_index     Int?     @default(100)
  reputation_updated_at String?
  /// Phase 2 — optional provider wallet auto-recharge
  auto_recharge_enabled   Boolean? @default(false)
  auto_recharge_threshold Float?   @default(10)
  auto_recharge_amount    Float?   @default(50)
}

model product_analytics_events {
  id          String  @id @default(uuid())
  event_name  String
  user_id     String?
  session_id  String?
  /// JSON blob: barber_id, booking_id, step_name, etc.
  properties  String?
  page_path   String?
  created_at  DateTime? @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamp(3)

  user        users?  @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([event_name, created_at])
  @@index([user_id, created_at])
  @@index([session_id, created_at])
  @@index([created_at])
}

model platform_events {
  id                     String  @id @default(uuid())
  title                  String
  description            String?
  event_type             String? @default("webinar")
  format                 String? @default("online")
  start_at               String
  end_at                 String?
  timezone               String? @default("UTC")
  location               String?
  meeting_url            String?
  image_url              String?
  max_capacity           Int?
  status                 String? @default("draft")
  target_audience        String? @default("all_providers")
  registration_opens_at  String?
  registration_closes_at String?
  created_by             String?
  created_at             String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at             String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  creator                users?  @relation("event_creator", fields: [created_by], references: [id], onDelete: SetNull)
  registrations          event_registrations[]

  @@index([status])
  @@index([start_at])
  @@index([target_audience])
}

model event_registrations {
  id            String  @id @default(uuid())
  event_id      String
  user_id       String
  status        String? @default("registered")
  registered_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  cancelled_at  String?
  attended_at   String?
  notes         String?

  event         platform_events @relation(fields: [event_id], references: [id], onDelete: Cascade)
  user          users           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([event_id, user_id])
  @@index([user_id])
  @@index([event_id, status])
}

model weekly_draws {
  id                  String  @id @default(uuid())
  title               String
  prize_title         String
  prize_description   String?
  week_start          String
  week_end            String
  draw_at             String
  status              String? @default("open")
  winner_user_id      String?
  winner_display_name String?
  total_tickets       Int?    @default(0)
  participant_count   Int?    @default(0)
  draw_seed           String?
  draw_hash           String?
  skill_question      String?
  skill_answer        String?
  completed_at        String?
  created_at          String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at          String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  winner              users?  @relation("draw_winner", fields: [winner_user_id], references: [id], onDelete: SetNull)
  entries             draw_entries[]
  winner_claim        draw_winner_claims?

  @@index([status])
  @@index([draw_at])
  @@index([week_start])
}

model draw_entries {
  id               String  @id @default(uuid())
  draw_id          String
  user_id          String
  participant_role String
  entry_count      Int?    @default(1)
  eligibility_json String?
  is_free_entry    Boolean? @default(false)
  created_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  draw             weekly_draws @relation(fields: [draw_id], references: [id], onDelete: Cascade)
  user             users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([draw_id, user_id])
  @@index([draw_id])
  @@index([user_id])
}

model draw_winner_claims {
  id           String  @id @default(uuid())
  draw_id      String  @unique
  user_id      String
  skill_answer String?
  skill_passed Boolean? @default(false)
  status       String? @default("pending")
  claimed_at   String?
  created_at   String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  draw         weekly_draws @relation(fields: [draw_id], references: [id], onDelete: Cascade)
  user         users        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model shops {
  id          String   @id @default(uuid())
  name        String
  location    String?
  image_url   String?
  description String?
  owner_id    String?
  rating      Float?   @default(0)
  review_count Int?    @default(0)
  /// Year the shop first opened (e.g. 2019)
  founded_year  Int?
  phone         String?
  website_url   String?
  instagram_handle String?
  /// JSON array of highlight tags shown on public profile
  profile_highlights String?
  created_at  String?  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at  String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  owner       users?   @relation("shop_owner", fields: [owner_id], references: [id])
  barbers     barbers[]
  services    services[]
  bookings    bookings[]
  shop_members shop_members[]
  products    products[]
  promo_codes promo_codes[]
  jobs        jobs[]
  inventory   shop_inventory_items[]
  expenses    shop_expenses[]
  service_bundles service_bundles[]
  chairs      shop_chairs[]
  accepts_cash_in_store Boolean? @default(false)
  provider_fee_wallet   provider_fee_wallets? @relation("shop_fee_wallet")
  fixed_fee_plans       provider_fixed_fee_plans[]
  /// JSON array of ISO-style language codes spoken by staff, e.g. ["en","el"]
  spoken_languages    String?
  /// Shop welcomes children / offers kid-friendly services
  children_friendly   Boolean? @default(false)
  /// Self-declared: shop holds valid business / grooming license
  attestation_licensed Boolean? @default(false)
  /// Self-declared: shop carries liability insurance
  attestation_insured  Boolean? @default(false)
  /// Require card on file at booking (Booksy/Squire-style)
  card_on_file_required Boolean? @default(false)
  /// In-shop visits at this location (default true)
  offers_shop_service   Boolean? @default(true)
  /// At-home visits offered under this shop brand
  offers_mobile_service Boolean? @default(false)
  /// Collect partial deposit at booking
  booking_deposit_enabled Boolean? @default(false)
  booking_deposit_percent Float? @default(20)
  booking_deposit_flat_amount Float?
  /// Authorize full service amount (capture on completion)
  booking_auth_hold_enabled Boolean? @default(false)
  /// Charge no-show fee from card on file
  no_show_protection_enabled Boolean? @default(false)
  no_show_fee_percent Float?
  no_show_fee_flat_amount Float?
  /// Late cancellation tiers (hours before appointment)
  late_cancel_protection_enabled Boolean? @default(true)
  late_cancel_full_refund_hours Float? @default(24)
  late_cancel_no_refund_hours Float? @default(2)
  late_cancel_fee_percent Float? @default(50)
  at_home_service_area at_home_service_areas?
  career_entries       provider_career_entries[]
}

model at_home_service_areas {
  id                  String   @id @default(uuid())
  barber_id           String?  @unique
  shop_id             String?  @unique
  base_address        String?
  base_latitude       Float?
  base_longitude      Float?
  /// Maximum travel distance from base (km)
  service_radius_km   Float    @default(25)
  travel_fees_enabled Boolean  @default(false)
  created_at          String?  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at          String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  barber barbers? @relation(fields: [barber_id], references: [id], onDelete: Cascade)
  shop   shops?   @relation(fields: [shop_id], references: [id], onDelete: Cascade)
  zones  at_home_travel_zones[]

  @@index([barber_id])
  @@index([shop_id])
}

model at_home_travel_zones {
  id              String  @id @default(uuid())
  area_id         String
  label           String
  min_distance_km Float   @default(0)
  max_distance_km Float
  fee_amount      Float   @default(0)
  sort_order      Int     @default(0)
  created_at      String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  area at_home_service_areas @relation(fields: [area_id], references: [id], onDelete: Cascade)

  @@index([area_id, sort_order])
}

model barbers {
  id          String   @id @default(uuid())
  user_id     String?
  shop_id     String?
  name        String
  title       String?  @default("Professional Barber")
  bio         String?
  image_url   String?
  rating      Float?   @default(0)
  review_count Int?    @default(0)
  location    String?
  latitude    Float?
  longitude   Float?
  city        String?
  status      String?  @default("active")
  /// JSON array of specialty tags, e.g. ["Fades","Beard","Color"]
  skills      String?
  years_experience Int?
  /// First year working as a barber/grooming professional
  career_started_year Int?
  /// Year mobile / at-home / van service began
  mobile_service_started_year Int?
  instagram_handle String?
  tiktok_handle    String?
  website_url      String?
  /// JSON array of highlight tags, e.g. ["Hot towel shaves","Kids welcome"]
  profile_highlights String?
  created_at  String?  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at  String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  user        users?   @relation(fields: [user_id], references: [id])
  shop        shops?   @relation(fields: [shop_id], references: [id])
  services    services[]
  bookings    bookings[]
  shifts      shifts[]
  time_blocks time_blocks[]
  payouts     payouts[]
  products    products[]
  videos      barber_videos[]
  waiting_list waiting_list_entries[]
  shop_members shop_members[]
  service_bundles service_bundles[]
  chair_assignments chair_assignments[]
  capacity_settings barber_capacity_settings?
  accepts_cash_in_store Boolean? @default(false)
  /// JSON array of ISO-style language codes, e.g. ["en","fr","el"]
  spoken_languages    String?
  /// Barber welcomes children / offers kid-friendly cuts
  children_friendly   Boolean? @default(false)
  /// Self-declared: barber holds valid professional license
  attestation_licensed Boolean? @default(false)
  /// Self-declared: barber carries liability insurance
  attestation_insured  Boolean? @default(false)
  /// Offers mobile / at-home visits
  offers_mobile_service Boolean? @default(false)
  /// Accepts clients at shop / chair (default true for existing barbers)
  offers_shop_service   Boolean? @default(true)
  /// Platform VIP tier (admin-granted or earned via rating threshold)
  is_vip                        Boolean? @default(false)
  /// VIP barbers can accept group bookings (parties, weddings, groomsmen)
  offers_group_booking          Boolean? @default(false)
  group_booking_min_party       Int?     @default(2)
  group_booking_max_party       Int?     @default(8)
  /// Percent discount on group subtotal (e.g. 10 = 10% off)
  group_booking_discount_percent Float?  @default(0)
  /// Require card on file at booking
  card_on_file_required Boolean? @default(false)
  booking_deposit_enabled Boolean? @default(false)
  booking_deposit_percent Float? @default(20)
  booking_deposit_flat_amount Float?
  booking_auth_hold_enabled Boolean? @default(false)
  no_show_protection_enabled Boolean? @default(false)
  no_show_fee_percent Float?
  no_show_fee_flat_amount Float?
  late_cancel_protection_enabled Boolean? @default(true)
  late_cancel_full_refund_hours Float? @default(24)
  late_cancel_no_refund_hours Float? @default(2)
  late_cancel_fee_percent Float? @default(50)
  /// Phase 2 — internal trust scores (not star rating)
  trust_score            Float?   @default(50)
  availability_score     Float?   @default(50)
  trust_score_updated_at String?
  language_program_waitlist language_program_waitlist[]
  fixed_fee_plans           provider_fixed_fee_plans[]
  at_home_service_area      at_home_service_areas?
  career_entries            provider_career_entries[]
  championship_scores       championship_scores[]
  championship_hall_of_fame championship_hall_of_fame[]

  @@index([user_id])
  @@index([shop_id])
  @@index([city])
  @@index([is_vip])
  @@index([offers_group_booking])
}

model services {
  id               String  @id @default(uuid())
  shop_id          String?
  barber_id        String?
  name             String
  category         String?
  description      String?
  price            Float
  duration_minutes Int
  image_url        String?
  created_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  shop             shops?  @relation(fields: [shop_id], references: [id])
  barber           barbers? @relation(fields: [barber_id], references: [id])
  booking_services booking_services[]
  staff_configs    staff_service_configs[]
  bundle_items     service_bundle_items[]

  @@index([shop_id])
  @@index([barber_id])
}

model bookings {
  id                 String  @id @default(uuid())
  client_id          String?
  barber_id          String
  shop_id            String?
  client_name        String?
  client_phone       String?
  client_email       String?
  guest_access_token String? @unique
  review_request_token String? @unique
  review_request_sent_at String?
  review_nudge_sent_at String?
  barber_name        String?
  service_name       String?
  service_snapshot   String?
  created_by         String?
  start_time         String
  end_time           String
  status             String? @default("pending")
  payment_status     String? @default("unpaid")
  payment_method     String? @default("online")
  platform_fee_status String? @default("not_applicable")
  platform_fee_amount Float?
  financial_breakdown String?
  price_at_booking   Float?
  notes              String?
  discount_code      String?
  booking_type       String? @default("individual")
  party_size         Int?
  group_event_label  String?
  group_notes        String?
  visit_type         String? @default("shop")
  location_text      String?
  client_latitude    Float?
  client_longitude   Float?
  travel_distance_km Float?
  travel_fee_amount  Float?
  travel_zone_label  String?
  date_text          String?
  time_text          String?
  sms_reminder_sent_at String?
  email_reminder_sent_at String?
  stripe_checkout_session_id String?
  stripe_payment_intent_id String?
  deposit_amount Float?
  deposit_payment_status String? @default("none")
  authorization_amount Float?
  authorization_status String? @default("none")
  balance_due Float?
  saved_payment_method_id String?
  no_show_fee_amount Float?
  no_show_fee_status String? @default("none")
  no_show_marked_at String?
  no_show_marked_by String?
  no_show_stripe_payment_intent_id String?
  cancellation_fee_amount Float?
  cancellation_fee_status String? @default("none")
  cancellation_refund_amount Float?
  cancellation_stripe_refund_id String?
  cancellation_stripe_payment_intent_id String?
  cancelled_by String?
  cancellation_tier String?
  chair_id           String?
  qr_check_in_token  String? @unique
  created_at         String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at         String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  client             users?  @relation("booking_client", fields: [client_id], references: [id])
  barber             barbers @relation(fields: [barber_id], references: [id])
  shop               shops?  @relation(fields: [shop_id], references: [id])
  booking_services   booking_services[]
  group_guests       group_booking_guests[]
  disputes           disputes[]
  reviews            reviews[]
  tip                booking_tips?
  check_in           booking_check_ins?
  chair              shop_chairs? @relation(fields: [chair_id], references: [id], onDelete: SetNull)

  @@index([client_id])
  @@index([barber_id, start_time])
  @@index([status])
  @@index([chair_id, start_time])
  @@index([discount_code])
  @@index([booking_type])
  @@index([visit_type])
  @@index([deposit_payment_status])
  @@index([authorization_status])
}

model client_payment_methods {
  id                       String  @id @default(uuid())
  user_id                  String
  stripe_payment_method_id String  @unique
  card_brand               String?
  card_last4               String?
  card_exp_month           Int?
  card_exp_year            Int?
  is_default               Boolean? @default(false)
  created_at               String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model group_booking_guests {
  id          String  @id @default(uuid())
  booking_id  String
  guest_name  String
  sort_order  Int?    @default(0)
  /// JSON array of service IDs for this guest
  service_ids String?
  notes       String?
  created_at  String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  booking     bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([booking_id])
}

model booking_services {
  id         Int    @id @default(autoincrement())
  booking_id String
  service_id String

  booking    bookings @relation(fields: [booking_id], references: [id])
  service    services @relation(fields: [service_id], references: [id])
}

model booking_tips {
  id                         String  @id @default(uuid())
  booking_id                 String  @unique
  client_id                  String
  recipient_user_id          String
  barber_id                  String
  shop_id                    String?
  amount                     Float
  currency                   String? @default("USD")
  percent_of_service         Float?
  message                    String?
  status                     String? @default("pending")
  stripe_checkout_session_id String?
  stripe_payment_intent_id   String?
  connect_transfer_id        String?
  paid_at                    String?
  created_at                 String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  booking   bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  client    users    @relation("tip_client", fields: [client_id], references: [id], onDelete: Cascade)
  recipient users    @relation("tip_recipient", fields: [recipient_user_id], references: [id], onDelete: Cascade)

  @@index([recipient_user_id])
  @@index([barber_id])
  @@index([client_id])
  @@index([status])
}

model products {
  id               String  @id @default(uuid())
  name             String
  description      String?
  price            Float
  image_url        String?
  category         String?
  seller_type      String
  barber_id        String?
  shop_id          String?
  vendor_name      String?
  brand_id         String?
  /// draft | pending_review | published | rejected
  status           String? @default("draft")
  published        Boolean? @default(false)
  featured         Boolean? @default(false)
  stock            Int?    @default(0)
  rejection_reason String?
  submitted_at     String?
  reviewed_at      String?
  reviewed_by      String?
  created_by       String?
  created_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  barber           barbers? @relation(fields: [barber_id], references: [id])
  shop             shops?   @relation(fields: [shop_id], references: [id])
  brand            brands?  @relation(fields: [brand_id], references: [id])
  creator          users?   @relation("product_creator", fields: [created_by], references: [id])
  reviewer         users?   @relation("product_reviewer", fields: [reviewed_by], references: [id])
  cart_items       cart_items[]
  order_items      order_items[]
  wishlist_items   wishlist_items[]
  reservations     marketplace_reservations[]

  @@index([published])
  @@index([status])
  @@index([seller_type])
  @@index([barber_id])
  @@index([shop_id])
  @@index([brand_id])
}

model saved_addresses {
  id         String   @id @default(uuid())
  user_id    String
  label      String?  @default("Home")
  full_name  String
  street     String
  city       String
