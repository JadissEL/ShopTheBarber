  health_status         String? @default("good")
  currency              String? @default("EUR")
  accepts_cash_in_store Boolean? @default(false)
  minimum_balance       Float?  @default(5)
  updated_at            String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user                  users   @relation(fields: [user_id], references: [id])
  shop                  shops?  @relation("shop_fee_wallet", fields: [shop_id], references: [id], onDelete: SetNull)
  transactions          provider_fee_transactions[]

  @@unique([user_id, shop_id])
  @@index([user_id])
}

model provider_fee_transactions {
  id                         String  @id @default(uuid())
  wallet_id                  String
  user_id                    String
  amount                     Float
  type                       String
  booking_id                 String?
  stripe_checkout_session_id String?
  description                String?
  created_at                 String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  wallet                     provider_fee_wallets @relation(fields: [wallet_id], references: [id])
  user                       users                @relation(fields: [user_id], references: [id])

  @@index([wallet_id])
  @@index([user_id])
  @@index([booking_id])
}

model provider_fixed_fee_plans {
  id                         String  @id @default(uuid())
  user_id                    String
  shop_id                    String?
  barber_id                  String?
  /// barber | shop
  scope                      String
  /// monthly | annual
  billing_cycle              String
  /// Calendar year this plan covers, e.g. 2026
  coverage_year              Int
  monthly_fee_amount         Float
  total_paid                 Float?  @default(0)
  discount_percent           Float?  @default(0)
  /// pending_payment | active | expired | cancelled
  status                     String? @default("pending_payment")
  /// unpaid | paid
  payment_status             String? @default("unpaid")
  period_start               String?
  period_end                 String?
  stripe_checkout_session_id String?
  enrolled_at                String?
  created_at                 String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at                 String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user                       users   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  shop                       shops?  @relation(fields: [shop_id], references: [id], onDelete: SetNull)
  barber                     barbers? @relation(fields: [barber_id], references: [id], onDelete: SetNull)

  @@unique([user_id, scope, coverage_year])
  @@index([user_id, status])
  @@index([coverage_year, status])
}

model wishlist_items {
  id         String  @id @default(uuid())
  user_id    String
  product_id String
  created_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user       users    @relation(fields: [user_id], references: [id])
  product    products @relation(fields: [product_id], references: [id])

  @@unique([user_id, product_id])
}

model barber_videos {
  id            String  @id @default(uuid())
  barber_id     String
  title         String
  video_url     String
  thumbnail_url String?
  status        String? @default("pending")
  views         Int?    @default(0)
  created_at    String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  barber        barbers @relation(fields: [barber_id], references: [id])

  @@index([barber_id])
}

/// Education, employment, certifications, milestones — shared career timeline for barbers & shops
model provider_career_entries {
  id            String  @id @default(uuid())
  barber_id     String?
  shop_id       String?
  /// education | employment | certification | milestone | award
  entry_type    String
  title         String
  organization  String?
  location      String?
  description   String?
  /// Year (2019) or ISO date string
  started_at    String?
  ended_at      String?
  is_current    Boolean? @default(false)
  sort_order    Int?     @default(0)
  created_at    String?  @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at    String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  barber barbers? @relation(fields: [barber_id], references: [id], onDelete: Cascade)
  shop   shops?   @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@index([barber_id, sort_order])
  @@index([shop_id, sort_order])
}

model feature_flags {
  id          String  @id @default(uuid())
  key         String  @unique
  label       String?
  description String?
  enabled     Boolean? @default(true)
  updated_at  String? @default(dbgenerated("CURRENT_TIMESTAMP"))
}

model shop_inventory_items {
  id            String  @id @default(uuid())
  shop_id       String
  name          String
  sku           String?
  quantity      Int?    @default(0)
  unit_cost     Float?
  reorder_level Int?    @default(5)
  created_at    String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  shop          shops   @relation(fields: [shop_id], references: [id])

  @@index([shop_id])
}

model shop_expenses {
  id           String  @id @default(uuid())
  shop_id      String
  category     String?
  amount       Float
  description  String?
  expense_date String?
  created_by   String?
  created_at   String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  shop         shops   @relation(fields: [shop_id], references: [id])
  creator      users?  @relation(fields: [created_by], references: [id])

  @@index([shop_id])
}

model language_programs {
  id                 String  @id @default(uuid())
  title              String
  description        String?
  /// Target language code barbers aim to learn, e.g. "en"
  language_code      String
  total_price        Float
  currency           String? @default("EUR")
  max_waitlist       Int?
  /// draft | open | closed | completed | cancelled
  status             String? @default("draft")
  estimated_start_at String?
  duration_weeks     Int?
  format             String? @default("online")
  image_url          String?
  created_by         String?
  created_at         String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at         String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  creator            users?  @relation("language_program_creator", fields: [created_by], references: [id], onDelete: SetNull)
  waitlist_entries   language_program_waitlist[]

  @@index([status])
  @@index([language_code])
}

model language_program_waitlist {
  id                         String  @id @default(uuid())
  program_id                 String
  user_id                    String
  barber_id                  String?
  target_language_code       String
  /// pending_payment | waitlisted | enrolled | cancelled
  status                     String? @default("pending_payment")
  deposit_percent            Float?  @default(20)
  deposit_amount             Float
  total_program_price        Float
  /// unpaid | paid | failed
  payment_status             String? @default("unpaid")
  stripe_checkout_session_id String?
  stripe_payment_intent_id   String?
  terms_accepted_at          String?
  terms_version              String?
  position                   Int?
  enrolled_at                String?
  cancelled_at               String?
  created_at                 String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  updated_at                 String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  program                    language_programs @relation(fields: [program_id], references: [id], onDelete: Cascade)
  user                       users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  barber                     barbers?          @relation(fields: [barber_id], references: [id], onDelete: SetNull)

  @@unique([program_id, user_id])
  @@index([user_id])
  @@index([program_id, status])
}

model legal_documents {
  id         String  @id @default(uuid())
  slug       String  @unique
  title      String
  content    String?
  version    String?
  published  Boolean? @default(true)
  updated_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))
}

/// GDPR / privacy audit trail (Neon production)
model privacy_audits {
  id           String   @id @default(uuid())
  user_id      String
  action_type  String
  status       String   @default("initiated")
  request_ip   String?
  user_agent   String?
  metadata     String?
  error_message String?
  initiated_at String?  @default(dbgenerated("CURRENT_TIMESTAMP"))
  completed_at String?

  user         users    @relation(fields: [user_id], references: [id])

  @@index([user_id, action_type])
}

// --- Financial & Trust Ecosystem Phase 1 ---

model ledger_entries {
  id           String  @id @default(uuid())
  entity_type  String
  entity_id    String
  event_type   String
  payload_json String?
  actor_id     String?
  created_at   String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  @@index([entity_type, entity_id])
  @@index([event_type])
}

model shop_chairs {
  id         String   @id @default(uuid())
  shop_id    String
  name       String
  is_active  Boolean? @default(true)
  sort_order Int?     @default(0)
  created_at String?  @default(dbgenerated("CURRENT_TIMESTAMP"))

  shop        shops              @relation(fields: [shop_id], references: [id])
  assignments chair_assignments[]
  bookings    bookings[]

  @@index([shop_id])
}

model chair_assignments {
  id             String  @id @default(uuid())
  chair_id       String
  barber_id      String
  day_of_week    String?
  effective_from String?
  effective_to   String?

  chair  shop_chairs @relation(fields: [chair_id], references: [id], onDelete: Cascade)
  barber barbers     @relation(fields: [barber_id], references: [id], onDelete: Cascade)

  @@index([chair_id])
  @@index([barber_id])
}

model barber_capacity_settings {
  id                     String @id @default(uuid())
  barber_id              String @unique
  default_buffer_minutes Int?   @default(0)

  barber barbers @relation(fields: [barber_id], references: [id], onDelete: Cascade)
}

model booking_check_ins {
  id         String  @id @default(uuid())
  booking_id String  @unique
  qr_token   String  @unique
  scanned_at String?
  scanned_by String?
  latitude   Float?
  longitude  Float?
  created_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  booking bookings @relation(fields: [booking_id], references: [id], onDelete: Cascade)

  @@index([qr_token])
}

model marketplace_reservations {
  id         String  @id @default(uuid())
  product_id String
  user_id    String
  quantity   Int?    @default(1)
  status     String? @default("active")
  expires_at String
  created_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  product products @relation(fields: [product_id], references: [id], onDelete: Cascade)
  user    users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([product_id, status])
  @@index([user_id])
}

model waitlist_offers {
  id                String  @id @default(uuid())
  waitlist_entry_id String
  slot_start        String
  slot_end          String?
  status            String? @default("pending")
  offer_expires_at  String
  created_at        String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  waitlist_entry waiting_list_entries @relation(fields: [waitlist_entry_id], references: [id], onDelete: Cascade)

  @@index([waitlist_entry_id])
  @@index([status, offer_expires_at])
}

// --- Financial & Trust Phase 2 / 3 ---

model reputation_events {
  id                String  @id @default(uuid())
  user_id           String
  event_type        String
  points_delta      Int?    @default(0)
  reliability_delta Int?    @default(0)
  payload_json      String?
  created_at        String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([event_type])
}

model championship_seasons {
  id         String  @id @default(uuid())
  name       String
  season_key String  @unique
  starts_at  String
  ends_at    String
  status     String? @default("active")
  created_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  scores     championship_scores[]
  hall_of_fame championship_hall_of_fame[]
}

model championship_scores {
  id              String  @id @default(uuid())
  season_id       String
  barber_id       String
  composite_score Float?  @default(0)
  rank            Int?
  country_code    String?
  badges_json     String?
  updated_at      String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  season championship_seasons @relation(fields: [season_id], references: [id], onDelete: Cascade)
  barber barbers              @relation(fields: [barber_id], references: [id], onDelete: Cascade)

  @@unique([season_id, barber_id])
  @@index([season_id, rank])
}

model championship_hall_of_fame {
  id         String  @id @default(uuid())
  season_id  String
  barber_id  String
  rank       Int
  badge      String?
  inducted_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  season championship_seasons @relation(fields: [season_id], references: [id], onDelete: Cascade)
  barber barbers              @relation(fields: [barber_id], references: [id], onDelete: Cascade)

  @@unique([season_id, barber_id])
}

model fraud_alerts {
  id          String  @id @default(uuid())
  entity_type String
  entity_id   String
  rule_id     String
  severity    String? @default("medium")
  payload_json String?
  status      String? @default("open")
  created_at  String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  resolved_at String?

  @@index([status, created_at])
  @@index([entity_type, entity_id])
}

model partner_api_keys {
  id           String  @id @default(uuid())
  name         String
  api_key_hash String  @unique
  scopes_json  String?
  rate_limit   Int?    @default(1000)
  is_active    Boolean? @default(true)
  created_at   String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  last_used_at String?

  @@index([is_active])
}

model ad_credit_wallets {
  id         String  @id @default(uuid())
  user_id    String  @unique
  balance    Float?  @default(0)
  currency   String? @default("EUR")
  updated_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user         users                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions ad_credit_transactions[]
}

model ad_credit_transactions {
  id          String  @id @default(uuid())
  wallet_id   String
  amount      Float
  type        String
  description String?
  created_at  String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  wallet ad_credit_wallets @relation(fields: [wallet_id], references: [id], onDelete: Cascade)

  @@index([wallet_id])
}

model dispute_appeals {
  id          String  @id @default(uuid())
  dispute_id  String
  appellant_id String
  reason      String
  status      String? @default("pending")
  created_at  String? @default(dbgenerated("CURRENT_TIMESTAMP"))
  resolved_at String?

  appellant users @relation(fields: [appellant_id], references: [id], onDelete: Cascade)

  @@index([dispute_id])
  @@index([status])
}

model wallet_reconciliation_runs {
  id               String  @id @default(uuid())
  wallet_id        String
  wallet_kind      String
  expected_balance Float
  actual_balance   Float
  delta            Float
  status           String? @default("ok")
  created_at       String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  @@index([wallet_id, created_at])
}

model financing_applications {
  id         String  @id @default(uuid())
  user_id    String
  amount     Float
  purpose    String?
  status     String? @default("pending")
  created_at String? @default(dbgenerated("CURRENT_TIMESTAMP"))

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status])
}
