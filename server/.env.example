# ShopTheBarber — Server environment (copy to .env and fill in)
# Do not commit .env; it may contain secrets.

# -----------------------------------------------------------------------------
# Database — Prisma + Neon PostgreSQL (REQUIRED, the only database)
# -----------------------------------------------------------------------------
# Neon connection string. Used by Prisma at build (migrate deploy) and runtime.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Optional: isolated Neon branch URL used by the test suite (NODE_ENV=test).
# TEST_DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Clerk (REQUIRED — the only authentication provider)
# -----------------------------------------------------------------------------
# Get keys from https://dashboard.clerk.com — same tenant as VITE_CLERK_PUBLISHABLE_KEY.
CLERK_SECRET_KEY=
# Optional duplicate for scripts; frontend uses root .env VITE_* only.
CLERK_PUBLISHABLE_KEY=

# Stripe (payments)
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for redirects and emails)
FRONTEND_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=Shop The Barber <onboarding@resend.dev>

# Optional: local AI endpoint (e.g. LM Studio)
# LOCAL_AI_ENDPOINT=http://localhost:1234/v1

# OAuth Configuration (Google Sign-In)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Configuration (Apple Sign-In)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3001
