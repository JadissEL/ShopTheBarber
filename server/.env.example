# ShopTheBarber — Server environment (copy to .env and fill in)
# Do not commit .env; it may contain secrets.

# -----------------------------------------------------------------------------
# JWT (required in production)
# -----------------------------------------------------------------------------
# Fastify registers @fastify/jwt with this secret. Used for legacy email/password
# tokens (/api/auth/login, register) and as the JWT fallback path when the
# Authorization Bearer token is not a valid Clerk token.
# Clerk is the primary interactive auth on the frontend, but JWT_SECRET stays
# required for secure server operation in production.
JWT_SECRET=

# -----------------------------------------------------------------------------
# Clerk (recommended for frontend sign-in — set both keys from dashboard)
# -----------------------------------------------------------------------------
# Get keys from https://dashboard.clerk.com — same tenant as VITE_CLERK_PUBLISHABLE_KEY.
CLERK_SECRET_KEY=
# Optional duplicate for scripts; frontend uses root .env VITE_* only.
CLERK_PUBLISHABLE_KEY=

# Optional: SQLite DB path (default: sovereign.sqlite in server dir)
# DATABASE_PATH=./sovereign.sqlite

# PostgreSQL (Neon recommended for production)
# DATABASE_URL=postgresql://...@ep-xxx-pooler....neon.tech/neondb?sslmode=require
# For Neon migrations, use the direct (non-pooler) host in DATABASE_URL when running prisma migrate locally
# USE_PRISMA_MIGRATE=true   # force Prisma migrations on any Postgres URL

# Stripe (payments)
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for redirects and emails)
FRONTEND_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=Shop The Barber <onboarding@resend.dev>

# Optional: local AI endpoint (e.g. LM Studio)
# LOCAL_AI_ENDPOINT=http://localhost:1234/v1

# OAuth Configuration (Google Sign-In)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Configuration (Apple Sign-In)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3001
