# ShopTheBarber — Server environment (copy to .env and fill in)
# Do not commit .env; it may contain secrets.

# Authentication (Clerk)
# Get your secret key from: https://dashboard.clerk.com
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Legacy JWT (deprecated - use Clerk instead)
# JWT_SECRET=your-jwt-secret-change-in-production

# Optional: SQLite DB path (default: sovereign.sqlite in server dir)
# DATABASE_PATH=./sovereign.sqlite

# Stripe (payments) — test mode: use sk_test_... and pk_test_... from Dashboard → API keys
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend URL (for redirects and emails)
FRONTEND_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=Shop The Barber <onboarding@resend.dev>

# Optional: local AI endpoint (e.g. LM Studio)
# LOCAL_AI_ENDPOINT=http://localhost:1234/v1

# OAuth Configuration (Google Sign-In)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI: http://localhost:3001/api/auth/google/callback (dev) or https://your-backend.com/api/auth/google/callback (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Configuration (Apple Sign-In)
# Get credentials from: https://developer.apple.com/account/resources/identifiers/list/serviceId
# 1. Create a Services ID
# 2. Enable Sign In with Apple
# 3. Add redirect URI: http://localhost:3001/api/auth/apple/callback (dev) or https://your-backend.com/api/auth/apple/callback (prod)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3001
