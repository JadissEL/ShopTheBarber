# ShopTheBarber — Server environment (copy to .env and fill in)
# Do not commit .env; it may contain secrets.

# -----------------------------------------------------------------------------
# Database — Prisma + Neon PostgreSQL (REQUIRED, the only database)
# -----------------------------------------------------------------------------
# Neon connection string. Used by Prisma at build (migrate deploy) and runtime.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Optional: isolated Neon branch URL used by the test suite (NODE_ENV=test).
# TEST_DATABASE_URL=postgresql://...neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Clerk (REQUIRED — the only authentication provider)
# -----------------------------------------------------------------------------
# Get keys from https://dashboard.clerk.com — same tenant as VITE_CLERK_PUBLISHABLE_KEY.
CLERK_SECRET_KEY=
# Optional duplicate for scripts; frontend uses root .env VITE_* only.
CLERK_PUBLISHABLE_KEY=

# Stripe (REQUIRED in production — gift cards, bookings, Connect payouts)
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe webhook endpoint: POST /api/webhooks/stripe
# Enable events: checkout.session.completed, charge.*, payment_intent.succeeded, payment_intent.payment_failed

# Frontend URL (for redirects and emails)
FRONTEND_URL=http://localhost:3000

# Protects POST /api/cron/* (booking reminders, auto-confirm, waitlist expiry, marketplace holds)
# Set the same value in GitHub Actions secrets: CRON_SECRET + PRODUCTION_API_URL
CRON_SECRET=

# Resend (transactional email) — required for email reminders
RESEND_API_KEY=
EMAIL_FROM=Shop The Barber <onboarding@resend.dev>

# Twilio (SMS booking reminders)
# https://console.twilio.com — Account SID, Auth Token, and a phone number with SMS capability.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Hours before appointment to send reminder (default 24)
SMS_REMINDER_HOURS_BEFORE=24
# Cron window width in minutes (default 60) — cron should run at least this often
SMS_REMINDER_WINDOW_MINUTES=60
# Set to false to disable all outbound SMS (logs only)
# SMS_REMINDERS_ENABLED=true
# Smart rebook nudges — text when client is usually due for another visit
# REBOOK_NUDGE_LEAD_DAYS=2
# REBOOK_NUDGE_GRACE_DAYS=3
# REBOOK_NUDGE_LOOKBACK_DAYS=180
# Twilio inbound SMS (STOP opt-out) — set in Twilio Console on your phone number:
# POST https://YOUR-API.onrender.com/api/webhooks/twilio/sms

# Marketplace retail — estimated VAT at checkout (Greece standard physical goods default 24%)
# MARKETPLACE_VAT_RATE=0.24

# OAuth Configuration (Google Sign-In)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Configuration (Apple Sign-In)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Geocoding & maps — Mapbox (recommended) or Google Maps
# -----------------------------------------------------------------------------
# Server geocoding: Mapbox Geocoding API or Google Geocoding API (auto-detected).
# Set GEOCODING_PROVIDER=mapbox|google|nominatim to force a provider (default: auto).
MAPBOX_ACCESS_TOKEN=
# Optional alternative to Mapbox — enable Geocoding API in Google Cloud Console.
GOOGLE_MAPS_API_KEY=
GEOCODING_PROVIDER=

# -----------------------------------------------------------------------------
# Rate limiting — Upstash Redis (REQUIRED in production)
# -----------------------------------------------------------------------------
# Create a free database at https://console.upstash.com — REST API (serverless-friendly).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Observability — Sentry (recommended for production)
# -----------------------------------------------------------------------------
# Create a Node.js project at https://sentry.io and paste the DSN here.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Fraction of transactions to trace (0.0–1.0). Default 0.1 in production.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional release identifier (git SHA). Render provides RENDER_GIT_COMMIT.
# SENTRY_RELEASE=
