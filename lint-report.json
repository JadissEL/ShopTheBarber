h-4\" /> Add address\r\n                </Button>\r\n            )}\r\n        </div>\r\n    );\r\n}\r\n\r\n/** Map saved address row ÔåÆ checkout shipping fields */\r\nexport function addressToShipping(addr) {\r\n    if (!addr) return null;\r\n    return {\r\n        fullName: addr.full_name,\r\n        street: addr.street,\r\n        city: addr.city,\r\n        state: addr.state || '',\r\n        zip: addr.zip,\r\n        phone: addr.phone || '',\r\n        savedAddressId: addr.id,\r\n    };\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\shipping\\SellerShippingProfile.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\theme-provider.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\tips\\TipBarber.jsx","messages":[{"ruleId":"unused-imports/no-unused-vars","severity":2,"message":"'queryClient' is assigned a value but never used. Allowed unused vars must match /^_/u.","line":16,"column":11,"nodeType":"Identifier","messageId":"unusedVar","endLine":16,"endColumn":22}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState } from 'react';\r\nimport { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';\r\nimport { sovereign } from '@/api/apiClient';\r\nimport { Button } from '@/components/ui/button';\r\nimport { Textarea } from '@/components/ui/textarea';\r\nimport { Label } from '@/components/ui/label';\r\nimport { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';\r\nimport { Heart, Loader, CheckCircle2, DollarSign } from 'lucide-react';\r\nimport { toast } from 'sonner';\r\n\r\nfunction formatMoney(amount) {\r\n    return `$${Number(amount).toFixed(2)}`;\r\n}\r\n\r\nexport default function TipBarber({ bookingId, returnPath, compact = false }) {\r\n    const queryClient = useQueryClient();\r\n    const [customAmount, setCustomAmount] = useState('');\r\n    const [selectedPreset, setSelectedPreset] = useState(null);\r\n    const [message, setMessage] = useState('');\r\n\r\n    const { data: tipStatus, isLoading } = useQuery({\r\n        queryKey: ['tip-status', bookingId],\r\n        queryFn: () => sovereign.tips.getBookingStatus(bookingId),\r\n        enabled: !!bookingId,\r\n    });\r\n\r\n    const checkoutMutation = useMutation({\r\n        mutationFn: (payload) => sovereign.tips.createCheckout({ booking_id: bookingId, ...payload, return_path: returnPath }),\r\n        onSuccess: (data) => {\r\n            if (data?.url) {\r\n                window.location.href = data.url;\r\n            } else {\r\n                toast.error('Could not start tip checkout');\r\n            }\r\n        },\r\n        onError: (err) => toast.error(err.message || 'Failed to start tip payment'),\r\n    });\r\n\r\n    if (isLoading) {\r\n        return (\r\n            <Card className={compact ? 'border-border' : 'border-amber-200/60 bg-amber-50/30'}>\r\n                <CardContent className=\"p-6 flex items-center justify-center gap-2 text-muted-foreground\">\r\n                    <Loader className=\"w-4 h-4 animate-spin\" /> Loading tip optionsÔÇª\r\n                </CardContent>\r\n            </Card>\r\n        );\r\n    }\r\n\r\n    if (!tipStatus?.can_tip && !tipStatus?.already_tipped) {\r\n        if (compact) return null;\r\n        return (\r\n            <Card className=\"border-border bg-muted/30\">\r\n                <CardContent className=\"p-4 text-sm text-muted-foreground\">\r\n                    {tipStatus?.reason || 'Tips will be available after your appointment is completed.'}\r\n                </CardContent>\r\n            </Card>\r\n        );\r\n    }\r\n\r\n    if (tipStatus?.already_tipped) {\r\n        return (\r\n            <Card className=\"border-green-200 bg-green-50/50\">\r\n                <CardContent className={`${compact ? 'p-4' : 'p-6'} flex items-center gap-3`}>\r\n                    <CheckCircle2 className=\"w-5 h-5 text-green-600 shrink-0\" />\r\n                    <div>\r\n                        <p className=\"font-semibold text-green-800\">Tip sent ÔÇö thank you!</p>\r\n                        <p className=\"text-sm text-green-700\">\r\n                            {formatMoney(tipStatus.tip?.amount)} to {tipStatus.recipient_name || 'your barber'}\r\n                        </p>\r\n                    </div>\r\n                </CardContent>\r\n            </Card>\r\n        );\r\n    }\r\n\r\n    const handleTip = (opts) => {\r\n        checkoutMutation.mutate({ ...opts, message: message.trim() || undefined });\r\n    };\r\n\r\n    const handleCustomTip = () => {\r\n        const amount = parseFloat(customAmount);\r\n        if (Number.isNaN(amount) || amount < (tipStatus.min_amount ?? 1)) {\r\n            toast.error(`Enter at least ${formatMoney(tipStatus.min_amount ?? 1)}`);\r\n            return;\r\n        }\r\n        handleTip({ amount });\r\n    };\r\n\r\n    return (\r\n        <Card className={compact ? 'border-border' : 'border-amber-200/60 bg-gradient-to-br from-amber-50/80 to-card shadow-md'}>\r\n            <CardHeader className={compact ? 'p-4 pb-2' : 'p-6 pb-3'}>\r\n                <CardTitle className={`flex items-center gap-2 ${compact ? 'text-base' : 'text-xl'}`}>\r\n                    <Heart className=\"w-5 h-5 text-amber-600 fill-amber-500/30\" />\r\n                    Say thanks with a tip\r\n                </CardTitle>\r\n                {!compact && (\r\n                    <p className=\"text-sm text-muted-foreground mt-1\">\r\n                        100% goes to {tipStatus.recipient_name || tipStatus.barber_name || 'your barber'}\r\n                        {tipStatus.service_price > 0 && ` ┬À Service was ${formatMoney(tipStatus.service_price)}`}\r\n                    </p>\r\n                )}\r\n            </CardHeader>\r\n            <CardContent className={`space-y-4 ${compact ? 'p-4 pt-0' : 'p-6 pt-0'}`}>\r\n                <div className=\"flex flex-wrap gap-2\">\r\n                    {(tipStatus.presets || []).map((preset) => (\r\n                        <Button\r\n                            key={preset.percent}\r\n                            type=\"button\"\r\n                            variant={selectedPreset === preset.percent ? 'default' : 'outline'}\r\n                            className=\"rounded-xl font-bold min-w-[4.5rem]\"\r\n                            disabled={checkoutMutation.isPending}\r\n                            onClick={() => {\r\n                                setSelectedPreset(preset.percent);\r\n                                setCustomAmount('');\r\n                                handleTip({ percent: preset.percent });\r\n                            }}\r\n                        >\r\n                            {preset.percent}%\r\n                            <span className=\"ml-1 text-xs opacity-80\">{formatMoney(preset.amount)}</span>\r\n                        </Button>\r\n                    ))}\r\n                </div>\r\n\r\n                <div className=\"flex gap-2 items-end\">\r\n                    <div className=\"flex-1\">\r\n                        <Label htmlFor={`custom-tip-${bookingId}`} className=\"text-xs text-muted-foreground\">\r\n                            Custom amount\r\n                        </Label>\r\n                        <div className=\"relative mt-1\">\r\n                            <DollarSign className=\"absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground\" />\r\n                            <input\r\n                                id={`custom-tip-${bookingId}`}\r\n                                type=\"number\"\r\n                                min={tipStatus.min_amount}\r\n                                max={tipStatus.max_amount}\r\n                                step=\"0.01\"\r\n                                placeholder=\"0.00\"\r\n                                value={customAmount}\r\n                                onChange={(e) => {\r\n                                    setCustomAmount(e.target.value);\r\n                                    setSelectedPreset(null);\r\n                                }}\r\n                                className=\"w-full pl-9 pr-3 py-2 rounded-xl border border-border bg-background text-sm\"\r\n                            />\r\n                        </div>\r\n                    </div>\r\n                    <Button\r\n                        type=\"button\"\r\n                        variant=\"secondary\"\r\n                        className=\"rounded-xl shrink-0\"\r\n                        disabled={checkoutMutation.isPending || !customAmount}\r\n                        onClick={handleCustomTip}\r\n                    >\r\n                        {checkoutMutation.isPending ? <Loader className=\"w-4 h-4 animate-spin\" /> : 'Tip'}\r\n                    </Button>\r\n                </div>\r\n\r\n                {!compact && (\r\n                    <div>\r\n                        <Label htmlFor={`tip-msg-${bookingId}`} className=\"text-xs text-muted-foreground\">\r\n                            Optional message\r\n                        </Label>\r\n                        <Textarea\r\n                            id={`tip-msg-${bookingId}`}\r\n                            placeholder=\"Great fade ÔÇö thanks!\"\r\n                            value={message}\r\n                            onChange={(e) => setMessage(e.target.value)}\r\n                            maxLength={280}\r\n                            className=\"mt-1 rounded-xl resize-none\"\r\n                            rows={2}\r\n                        />\r\n                    </div>\r\n                )}\r\n            </CardContent>\r\n        </Card>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\GlobalNavigation.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\SkipLink.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\alert.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\avatar.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\back-navigation.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\badge.jsx","messages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants