n\r\n  const closeMutation = useMutation({\r\n    mutationFn: (id) => sovereign.jobs.close(id),\r\n    onSuccess: () => {\r\n      toast.success('Job closed ÔÇö no longer accepting applications');\r\n      invalidate();\r\n    },\r\n    onError: (e) => toast.error(e.message),\r\n  });\r\n\r\n  const deleteMutation = useMutation({\r\n    mutationFn: (id) => sovereign.jobs.delete(id),\r\n    onSuccess: () => {\r\n      toast.success('Job deleted');\r\n      invalidate();\r\n    },\r\n    onError: (e) => toast.error(e.message),\r\n  });\r\n\r\n  if (!isAuthenticated) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background flex flex-col items-center justify-center p-4\">\r\n        <MetaTags title=\"My job postings | Shop The Barber\" />\r\n        <p className=\"text-slate-600 mb-4\">Sign in to manage your job postings.</p>\r\n        <Button onClick={() => navigate(createPageUrl('SignIn') + '?return=' + encodeURIComponent('/MyJobs'))}>Sign in</Button>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background pb-24 lg:pb-8\">\r\n      <MetaTags title=\"My job postings | Shop The Barber\" />\r\n      <div className=\"max-w-4xl mx-auto px-4 py-6\">\r\n        <div className=\"flex items-center justify-between mb-2\">\r\n          <h1 className=\"text-2xl font-bold text-foreground\">My job postings</h1>\r\n          <Button onClick={() => navigate(createPageUrl('CreateJob'))} className=\"bg-primary text-white rounded-xl gap-2\">\r\n            <Plus className=\"w-5 h-5\" /> New opening\r\n          </Button>\r\n        </div>\r\n        <p className=\"text-sm text-muted-foreground mb-6\">\r\n          Create a draft, submit for review, and an admin will approve before it goes live on Career Hub.\r\n        </p>\r\n        {isLoading ? (\r\n          <p className=\"text-slate-500\">LoadingÔÇª</p>\r\n        ) : jobs.length === 0 ? (\r\n          <div className=\"bg-white rounded-2xl border border-slate-200 p-8 text-center\">\r\n            <Briefcase className=\"w-12 h-12 text-slate-300 mx-auto mb-3\" />\r\n            <p className=\"text-slate-600 mb-4\">No job postings yet.</p>\r\n            <Button onClick={() => navigate(createPageUrl('CreateJob'))} className=\"bg-primary text-white\">Create your first job</Button>\r\n          </div>\r\n        ) : (\r\n          <ul className=\"space-y-3\">\r\n            {jobs.map((job) => (\r\n              <li key={job.id} className=\"p-4 bg-white rounded-xl border border-slate-200 hover:shadow-sm\">\r\n                <div className=\"flex flex-wrap items-start justify-between gap-3\">\r\n                  <Link to={createPageUrl('ApplicantReview') + '?jobId=' + encodeURIComponent(job.id)} className=\"min-w-0 flex-1\">\r\n                    <p className=\"font-semibold text-foreground\">{job.title}</p>\r\n                    <p className=\"text-sm text-slate-500\">{job.employer_name}</p>\r\n                    {job.status === 'rejected' && job.rejection_reason && (\r\n                      <p className=\"text-xs text-red-600 mt-1\">Feedback: {job.rejection_reason}</p>\r\n                    )}\r\n                  </Link>\r\n                  <div className=\"flex flex-wrap items-center gap-2 shrink-0\">\r\n                    <span className={`px-2.5 py-1 rounded-full text-xs font-medium ${STATUS_STYLES[job.status] || STATUS_STYLES.draft}`}>\r\n                      {STATUS_LABELS[job.status] || job.status}\r\n                    </span>\r\n                    {(job.status === 'draft' || job.status === 'rejected') && (\r\n                      <>\r\n                        <Button\r\n                          size=\"sm\"\r\n                          className=\"rounded-lg gap-1\"\r\n                          onClick={(e) => { e.preventDefault(); submitMutation.mutate(job.id); }}\r\n                          disabled={submitMutation.isPending}\r\n                        >\r\n                          <Send className=\"w-3.5 h-3.5\" /> Submit\r\n                        </Button>\r\n                        <Button\r\n                          size=\"sm\"\r\n                          variant=\"outline\"\r\n                          className=\"rounded-lg text-red-600\"\r\n                          onClick={(e) => { e.preventDefault(); deleteMutation.mutate(job.id); }}\r\n                          disabled={deleteMutation.isPending}\r\n                        >\r\n                          <Trash2 className=\"w-3.5 h-3.5\" />\r\n                        </Button>\r\n                      </>\r\n                    )}\r\n                    {job.status === 'published' && (\r\n                      <Button\r\n                        size=\"sm\"\r\n                        variant=\"outline\"\r\n                        className=\"rounded-lg text-slate-600 gap-1\"\r\n                        onClick={(e) => { e.preventDefault(); closeMutation.mutate(job.id); }}\r\n                        disabled={closeMutation.isPending}\r\n                      >\r\n                        <Ban className=\"w-3.5 h-3.5\" /> Close\r\n                      </Button>\r\n                    )}\r\n                    <Link to={createPageUrl('ApplicantReview') + '?jobId=' + encodeURIComponent(job.id)} className=\"text-slate-400 hover:text-slate-600 px-1\" aria-label=\"Review applicants\">ÔåÆ</Link>\r\n                  </div>\r\n                </div>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\MyOrders.jsx","messages":[{"ruleId":"prefer-template","severity":1,"message":"Unexpected string concatenation.","line":34,"column":16,"nodeType":"BinaryExpression","messageId":"unexpectedStringConcatenation","endLine":34,"endColumn":86,"fix":{"range":[1198,1268],"text":"`${createPageUrl('SignIn')  }?return=${  encodeURIComponent('/MyOrders')}`"}},{"ruleId":"prefer-template","severity":1,"message":"Unexpected string concatenation.","line":82,"column":25,"nodeType":"BinaryExpression","messageId":"unexpectedStringConcatenation","endLine":82,"endColumn":95,"fix":{"range":[3203,3273],"text":"`${createPageUrl('OrderTracking')  }?id=${  encodeURIComponent(order.id)}`"}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":2,"source":"import { useQuery } from '@tanstack/react-query';\r\nimport { Link, useNavigate } from 'react-router-dom';\r\nimport { useEffect } from 'react';\r\nimport { Package, ChevronRight } from 'lucide-react';\r\nimport { PageLoading } from '@/components/ui/page-loading';\r\nimport { EmptyState } from '@/components/ui/empty-state';\r\nimport { MetaTags } from '@/components/seo/MetaTags';\r\nimport { sovereign } from '@/api/apiClient';\r\nimport { useAuth } from '@/lib/AuthContext';\r\nimport { createPageUrl } from '@/utils';\r\nconst STATUS_LABELS = {\r\n  confirmed: 'Preparing',\r\n  preparing: 'Preparing',\r\n  in_transit: 'In Transit',\r\n  delivered: 'Delivered',\r\n  paid: 'Confirmed',\r\n  pending: 'Pending',\r\n};\r\n\r\nexport default function MyOrders() {\r\n  const navigate = useNavigate();\r\n  const { isAuthenticated, isLoading: isAuthLoading } = useAuth();\r\n\r\n  const { data: orders = [], isLoading } = useQuery({\r\n    queryKey: ['my-orders'],\r\n    queryFn: () => sovereign.orders.list(),\r\n    enabled: isAuthenticated,\r\n    staleTime: 60 * 1000,\r\n  });\r\n\r\n  // Redirect if not authenticated (useEffect to avoid render-phase side effects)\r\n  useEffect(() => {\r\n    if (!isAuthLoading && !isAuthenticated) {\r\n      navigate(createPageUrl('SignIn') + '?return=' + encodeURIComponent('/MyOrders'), { replace: true });\r\n    }\r\n  }, [isAuthenticated, isAuthLoading, navigate]);\r\n\r\n  // Show loading while checking auth\r\n  if (isAuthLoading) {\r\n    return <PageLoading message=\"Checking authentication...\" />;\r\n  }\r\n\r\n  if (!isAuthenticated) {\r\n    return null; // Will redirect in useEffect\r\n  }\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background pb-24 lg:pb-8\">\r\n      <MetaTags\r\n        title=\"My Orders ÔÇô Shop The Barber\"\r\n        description=\"View and track your premium grooming orders.\"\r\n      />\r\n\r\n      <header className=\"sticky top-0 z-40 bg-card border-b border-border\">\r\n        <div className=\"w-full max-w-2xl mx-auto px-4 lg:px-8 py-4\">\r\n          <h1 className=\"text-xl font-bold text-foreground\">My Orders</h1>\r\n          <p className=\"text-sm text-muted-foreground mt-0.5\">Track your marketplace orders</p>\r\n        </div>\r\n      </header>\r\n\r\n      <main className=\"w-full max-w-2xl mx-auto px-4 lg:px-8 py-6\">\r\n        {isLoading ? (\r\n          <PageLoading message=\"Loading orders...\" />\r\n        ) : orders.length === 0 ? (\r\n          <EmptyState\r\n            icon={Package}\r\n            title=\"No orders yet\"\r\n            description=\"Orders from the Marketplace will appear here.\"\r\n            actionLabel=\"Browse Marketplace\"\r\n            actionHref={createPageUrl('Marketplace')}\r\n          />\r\n        ) : (\r\n          <ul className=\"space-y-4\">\r\n            {orders.map((order) => {\r\n              const orderNum = order.order_number || `#${order.id?.slice(-8) || ''}`;\r\n              const dateStr = order.created_at ? new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '';\r\n              const status = order.fulfillment_status || order.status || 'paid';\r\n              const statusLabel = STATUS_LABELS[status] || status;\r\n              return (\r\n                <li key={order.id}>\r\n                  <Link\r\n                    to={createPageUrl('OrderTracking') + '?id=' + encodeURIComponent(order.id)}\r\n                    className=\"block rounded-2xl border border-border bg-card p-4 hover:border-primary/30 hover:shadow-sm transition-all\"\r\n                  >\r\n                    <div className=\"flex items-center justify-between gap-4\">\r\n                      <div className=\"min-w-0\">\r\n                        <p className=\"font-semibold text-foreground\">Order {orderNum}</p>\r\n                        <p className=\"text-sm text-muted-foreground mt-0.5\">{dateStr}</p>\r\n                        <p className=\"text-sm font-medium text-foreground mt-1\">${Number(order.total).toFixed(2)}</p>\r\n                        <span className=\"inline-block mt-2 text-xs font-medium text-sky-600 bg-sky-50 px-2 py-1 rounded\">\r\n                          {statusLabel}\r\n                        </span>\r\n                      </div>\r\n                      <ChevronRight className=\"w-5 h-5 text-slate-400 shrink-0\" />\r\n                    </div>\r\n                  </Link>\r\n                </li>\r\n              );\r\n            })}\r\n          </ul>\r\n        )}\r\n      </main>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\NotificationSettings.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\Offline.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\Onboarding.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\OrderTracking.jsx","messages":[{"ruleId":"prefer-template","severity":1,"message":"Unexpected string concatenation.","line":20,"column":22,"nodeType":"BinaryExpression","messageId":"unexpectedStringConcatenation","endLine":20,"endColumn":46,"fix":{"range":[1093,1117],"text":"`${isoDateStr  }T12:00:00`"}},{"ruleId":"prefer-template","severity":1,"message":"Unexpected string concatenation.","line":61,"column":14,"nodeType":"BinaryExpression","messageId":"unexpectedStringConcatenation","endLine":61,"endColumn":103,"fix":{"range":[3157,3246],"text":"`${createPageUrl('SignIn')  }?return=${  encodeURIComponent(`/OrderTracking?id=${orderId}`)}`"}}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":2,"source":"import { useSearchParams, Link, useNavigate } from 'react-router-dom';\r\nimport { useQuery } from '@tanstack/react-query';\r\nimport { ChevronLeft, Check, Circle, Truck, Package, Headphones } from 'lucide-react';\r\nimport { MetaTags } from '@/components/seo/MetaTags';\r\nimport { Button } from '@/components/ui/button';\r\nimport { OptimizedImage } from '@/components/ui/optimized-image';\r\nimport { PageLoading } from '@/components/ui/page-loading';\r\nimport { sovereign } from '@/api/apiClient';\r\nimport { useAuth } from '@/lib/AuthContext';\r\nimport { createPageUrl } from '@/utils';\r\nconst JOURNEY_STEPS = [\r\n  { key: 'confirmed', label: 'Order Confirmed', sub: null, icon: Check },\r\n  { key: 'preparing', label: 'Preparing Your Selection', sub: 'Our grooming consultants are curating your kit', icon: Circle },\r\n  { key: 'in_transit', label: 'In Transit', sub: 'Elite Courier Logistics', icon: Truck },\r\n  { key: 'delivered', label: 'Delivered', sub: 'Signature required', icon: Package },\r\n];\r\n\r\nfunction formatEstimatedArrival(isoDateStr) {\r\n  if (!isoDateStr) return null;\r\n  const d = new Date(isoDateStr + 'T12:00:00');\r\n  const options = { weekday: 'long', month: 'short', day: 'numeric' };\r\n  const formatted = d.toLocaleDateString('en-US', options);\r\n  const day = d.getDate();\r\n  const suffix = day === 1 || day === 21 || day === 31 ? 'st' : day === 2 || day === 22 ? 'nd' : day === 3 || day === 23 ? 'rd' : 'th';\r\n  return formatted.replace(String(day), day + suffix);\r\n}\r\n\r\nexport default function OrderTracking() {\r\n  const [searchParams] = useSearchParams();\r\n  const navigate = useNavigate();\r\n  const orderId = searchParams.get('id');\r\n  const { isAuthenticated } = useAuth();\r\n\r\n  const { data: order, isLoading, error } = useQuery({\r\n    queryKey: ['order', orderId],\r\n    queryFn: () => sovereign.orders.get(orderId),\r\n    enabled: !!orderId && isAuthenticated,\r\n    staleTime: 60 * 1000,\r\n  });\r\n\r\n  const customerName = order?.shipping_full_name?.split(' ')[0] || 'there';\r\n  const orderNumber = order?.order_number || (order?.id ? `#${order.id.slice(-8).toUpperCase()}` : '');\r\n  const estimatedDateRaw = order?.estimated_delivery_at || (order?.created_at ? (() => { const d = new Date(order.created_at); d.setDate(d.getDate() + 3); return d.toISOString().slice(0, 10); })() : null);\r\n  const estimatedDate = estimatedDateRaw ? formatEstimatedArrival(estimatedDateRaw) : null;\r\n  const fulfillmentStatus = order?.fulfillment_status || 'confirmed';\r\n  const fulfillments = order?.fulfillments || [];\r\n  const statusOrder = { confirmed: 0, preparing: 1, in_transit: 2, delivered: 3 };\r\n  const currentStepIndex = statusOrder[fulfillmentStatus] ?? 1;\r\n\r\n  if (!orderId) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background pb-24 lg:pb-8 flex flex-col items-center justify-center px-4\">\r\n        <MetaTags title=\"Order Tracking\" description=\"Track your order.\" />\r\n        <p className=\"text-slate-600 mb-4\">No order specified.</p>\r\n        <Link to={createPageUrl('Dashboard')}><Button variant=\"outline\" className=\"rounded-xl\">Back to Dashboard</Button></Link>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (!isAuthenticated) {\r\n    navigate(createPageUrl('SignIn') + '?return=' + encodeURIComponent(`/OrderTracking?id=${orderId}`));\r\n    return null;\r\n  }\r\n\r\n  if (isLoading) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background pb-24 lg:pb-8\">\r\n        <PageLoading message=\"Loading order details...\" />\r\n      </div>\r\n    );\r\n  }\r\n\r\n  if (error || !order) {\r\n    return (\r\n      <div className=\"min-h-screen bg-background pb-24 lg:pb-8 flex flex-col items-center justify-center px-4\">\r\n        <MetaTags title=\"Order Not Found\" description=\"Order not found.\" />\r\n        <p className=\"text-slate-600 mb-4\">Order not found.</p>\r\n        <Link to={createPageUrl('Dashboard')}><Button variant=\"outline\" className=\"rounded-xl\">Back to Dashboard</Button></Link>\r\n      </div>\r\n    );\r\n  }\r\n\r\n  const items = order.items || [];\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-background pb-24 lg:pb-8\">\r\n      <MetaTags\r\n        title={`Tracking ÔÇô Order ${orderNumber}`}\r\n        description=\"Track your premium grooming order.\"\r\n      />\r\n\r\n      <header className=\"sticky top-0 z-40 bg-white border-b border-slate-100\">\r\n        <div className=\"w-full max-w-2xl mx-auto px-4 lg:px-8 py-4 flex items-center justify-between\">\r\n          <button\r\n            type=\"button\"\r\n            onClick={() => navigate(-1)}\r\n            className=\"p-2 -ml-2 rounded-full text-sky-600 hover:bg-sky-50\"\r\n            aria-label=\"Back\"\r\n          >\r\n            <ChevronLeft className=\"w-5 h-5\" />\r\n          </button>\r\n          <h1 className=\"text-lg font-semibold text-foreground uppercase tracking-[0.2em]\" style={{ fontFamily: 'var(--font-serif, Georgia, serif)' }}>\r\n            Tracking\r\n          </h1>\r\n          <span className=\"w-9\" />\r\n        </div>\r\n      </header>\r\n\r\n      <main className=\"w-full max-w-2xl mx-auto px-4 lg:px-8 py-8\">\r\n        <div className=\"text-center mb-8\">\r\n          <div className=\"w-16 h-16 rounded-full bg-sky-100 flex items-center justify-center mx-auto mb-4\">\r\n            <Check className=\"w-8 h-8 text-sky-600\" strokeWidth={2.5} />\r\n          </div>\r\n          <h2 className=\"text-2xl font-bold text-foreground mb-1\" style={{ fontFamily: 'var(--font-serif, Georgia, serif)' }}>\r\n            Thank You, {customerName}\r\n          </h2>\r\n          <p className=\"text-sm text-slate-500 font-medium\">ORDER {orderNumber}</p>\r\n        </div>\r\n\r\n        {estimatedDate && (\r\n          <section className=\"rounded-2xl border border-slate-200 bg-white p-5 mb-8 shadow-sm\">\r\n            <p className=\"text-xs font-semibold uppercase tracking-wider text-sky-600 mb-1\">Estimated Arrival</p>\r\n            <p className=\"text-xl font-bold text-foreground mb-0.5\" style={{ fontFamily: 'var(--font-serif, Georgia, serif)' }}>\r\n              {estimatedDate}\r\n            </p>\r\n            <p className=\"text-sm text-slate-500\">Via Premium White-Glove Courier</p>\r\n          </section>\r\n        )}\r\n\r\n        {(order.tracking_number || fulfillments.some((f) => f.tracking_number)) && (\r\n          <section className=\"rounded-2xl border border-slate-200 bg-white p-5 mb-8 shadow-sm\">\r\n            <p className=\"text-xs font-semibold uppercase tracking-wider text-sky-600 mb-2\">Tracking</p>\r\n            {fulfillments.filter((f) => f.tracking_number).length > 0 ? (\r\n              <ul className=\"space-y-2\">\r\n                {fulfillments.filter((f) => f.tracking_number).map((f) => (\r\n                  <li key={f.id} className=\"text-sm\">\r\n                    <span className=\"font-medium capitalize\">{f.carrier || 'Carrier'}: </span>\r\n                    <span className=\"font-mono\">{f.tracking_number}</span>\r\n                    <span className=\"text-muted-foreground ml-2 capitalize\">({f.fulfillment_status?.replace('_', ' ')})</span>\r\n                  </li>\r\n                ))}\r\n              </ul>\r\n            ) : (\r\n              <p className=\"text-sm font-mono\">{order.tracking_number}{order.carrier ? ` ┬À ${order.carrier}` : ''}</p>\r\n            )}\r\n          </section>\r\n        )}\r\n\r\n        {(order.shipping_street || order.shipping_full_name) && (\r\n          <section className=\"rounded-2xl border border-slate-200 bg-white p-5 mb-8 shadow-sm text-sm\">\r\n            <p className=\"text-xs font-semibold uppercase tracking-wider text-sky-600 mb-2\">Deliver to</p>\r\n            <p className=\"font-medium\">{order.shipping_full_name}</p>\r\n            <p className=\"text-muted-foreground\">{order.shipping_street}</p>\r\n            <p className=\"text-muted-foreground\">\r\n              {order.shipping_city}{order.shipping_state ? `, ${order.shipping_state}` : ''} {order.shipping_zip}\r\n            </p>\r\n          </section>\r\n        )}\r\n\r\n        <section className=\"mb-8\">\r\n          <h3 className=\"text-lg font-bold text-foreground mb-5\" style={{ fontFamily: 'var(--font-serif, Georgia, serif)' }}>\r\n            Order Journey\r\n          </h3>\r\n          <div className=\"relative pl-8 border-l-2 border-slate-200 ml-1\">\r\n            {JOURNEY_STEPS.map((step, i) => {\r\n              const isDone = i < currentStepIndex;\r\n              const isCurrent = i === currentStepIndex;\r\n              const isPending = i > currentStepIndex;\r\n              const Icon = step.icon;\r\n              return (\r\n                <div key={step.key} className=\"relative pb-6 last:pb-0\">\r\n                  <div className=\"absolute -left-8 top-0 flex items-center justify-center w-6 h-6 rounded-full bg-white border-2 border-slate-200\">\r\n                    {isDone ? (\r\n                      <Check className=\"w-3.5 h-3.5 text-sky-600\" strokeWidth={2.5} />\r\n                    ) : isCurrent ? (\r\n                      <Circle className=\"w-3.5 h-3.5 text-sky-600 fill-sky-600\" strokeWidth={2} />\r\n                    ) : (\r\n                      <Icon className={`w-3.5 h-3.5 ${isPending ? 'text-slate-300' : 'text-sky-600'}`} strokeWidth={2} />\r\n                    )}\r\n                  </div>\r\n                  <div className={`${isPending ? 'text-muted-foreground' : 'text-foreground'}`}>\r\n                    <p className=\"font-semibold text-sm\">{step.label}</p>\r\n                    {step.sub && (\r\n                      <p className={`text-xs mt-0.5 ${isCurrent ? 'text-sky-600 italic' : 'text-slate-500'}`}>{step.sub}</p>\r\n                    )}\r\n                    {i === 0 && order?.created_at && (\r\n                      <p className=\"text-xs text-slate-500 mt-0.5\">\r\n                        {new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })}\r\n                      </p>\r\n                    )}\r\n                  </div>\r\n                </div>\r\n              );\r\n            })}\r\n          </div>\r\n        </section>\r\n\r\n        <section className=\"mb-8\">\r\n          <h3 className=\"text-lg font-bold text-foreground mb-4\" style={{ fontFamily: 'var(--font-serif, Georgia, serif)' }}>\r\n            Your Selection\r\n          </h3>\r\n          <ul className=\"space-y-4\">\r\n            {items.map((item) => (\r\n              <li key={item.id} className=\"rounded-2xl border border-slate-200 bg-white p-4 flex gap-4 shadow-sm\">\r\n                <div className=\"w-20 h-20 rounded-xl overflow-hidden bg-slate-100 shrink-0\">\r\n                  <OptimizedImage\r\n                    src={item.product_image_url || ''}\r\n                    alt={item.product_name}\r\n                    className=\"w-full h-full object-cover\"\r\n                    width={80}\r\n                  />\r\n                </div>\r\n                <div className=\"flex-1 min-w-0\">\r\n                  <p className=\"text-xs uppercase tracking-wider text-muted-foreground font-medium\">Elite Grooming</p>\r\n                  <p className=\"font-semibold text-foreground\">{item.product_name}</p>\r\n                  <p className=\"text-sm text-slate-500 mt-0.5\">Qty: {item.quantity}</p>\r\n                  <p className=\"font-bold text-foreground mt-1\">${(Number(item.price) * (item.quantity || 1)).toFixed(2)}</p>\r\n                </div>\r\n              </li>\r\n            ))}\r\n          </ul>\r\n        </section>\r\n\r\n        <div className=\"mb-6\">\r\n          <p className=\"text-sm text-slate-600 mb-4\">\r\n            Your personal grooming consultant is available for any delivery adjustments or styling advice.\r\n          </p>\r\n          <Link to={createPageUrl('SupportChat') + (order?.id ? `?order_id=${order.id}&new=1` : '?new=1')}>\r\n            <Button className=\"w-full rounded-xl h-12 bg-white border-2 border-sky-600 text-sky-600 hover:bg-sky-50 font-semibold gap-2\" variant=\"outline\">\r\n              <Headphones className=\"w-5 h-5\" />\r\n              Contact Concierge\r\n            </Button>\r\n          </Link>\r\n        </div>\r\n\r\n        <p className=\"text-center text-xs text-muted-foreground uppercase tracking-[0.25em]\">\r\n          Elite Grooming Marketplace\r\n        </p>\r\n      </main>\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\PaymentError.jsx","messages":[{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":64,"column":33,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[2331,2402],"text":"\r\n                Votre paiement n&apos;a pas pu ├¬tre trait├®\r\n              "},"desc":"Replace with `&apos;`."