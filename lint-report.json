nk\"} [variant]\n * @property {\"default\" | \"sm\" | \"lg\" | \"icon\"} [size]\n * @property {boolean} [asChild]\n * @property {React.ReactNode} [children]\n */\n\n/** @type {React.ForwardRefExoticComponent<ButtonProps & React.ButtonHTMLAttributes<HTMLButtonElement>>} */\nconst Button = React.forwardRef(\n  ({ className, variant, size, asChild = false, children, ...props }, ref) => {\n    const Comp = asChild ? Slot : \"button\"\n    return (\n      <Comp\n        className={cn(buttonVariants({ variant, size, className }))}\n        ref={ref}\n        {...props}\n      >\n        {children}\n      </Comp>\n    );\n  }\n)\nButton.displayName = \"Button\"\n\nexport { Button, buttonVariants }\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\calendar.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\card.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\checkbox.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\collapsible.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\components\\ui\\dialog.jsx","messages":[],"suppressedMessages":[],"er