ion 'reviewRoutes' has no 'await' expression.","line":24,"column":8,"nodeType":"FunctionDeclaration","messageId":"missingAwait","endLine":24,"endColumn":35,"suggestions":[{"messageId":"removeAsync","fix":{"range":[680,686],"text":""},"desc":"Remove 'async'."}]}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":1,"fixableWarningCount":0,"source":"import { FastifyInstance } from 'fastify';\r\nimport { authenticateRequest } from '../auth/requestUser';\r\nimport {\r\n    submitReview,\r\n    getBookingReviewStatus,\r\n    listPublicReviews,\r\n    listProviderReviews,\r\n    type ReviewTargetType,\r\n} from './logic';\r\n\r\ntype AuthUser = { id: string };\r\n\r\nasync function requireAuth(request: any, reply: any): Promise<AuthUser | null> {\r\n    const ok = await authenticateRequest(request, reply);\r\n    if (!ok) return null;\r\n    return request.user as AuthUser;\r\n}\r\n\r\nfunction parseTargetType(value: string | undefined): ReviewTargetType | null {\r\n    if (value === 'barber' || value === 'shop') return value;\r\n    return null;\r\n}\r\n\r\nexport async function reviewRoutes(fastify: FastifyInstance) {\r\n    fastify.get('/api/reviews/public', async (request, reply) => {\r\n        const q = request.query as {\r\n            target_type?: string;\r\n            target_id?: string;\r\n            limit?: string;\r\n            offset?: string;\r\n            min_rating?: string;\r\n        };\r\n        const targetType = parseTargetType(q.target_type);\r\n        if (!targetType || !q.target_id) {\r\n            return reply.status(400).send({ error: 'target_type (barber|shop) and target_id are required' });\r\n        }\r\n        const reviews = await listPublicReviews({\r\n            target_type: targetType,\r\n            target_id: q.target_id,\r\n            limit: q.limit ? Number(q.limit) : 20,\r\n            offset: q.offset ? Number(q.offset) : 0,\r\n            min_rating: q.min_rating ? Number(q.min_rating) : undefined,\r\n        });\r\n        return { reviews };\r\n    });\r\n\r\n    fastify.get('/api/reviews/provider', async (request, reply) => {\r\n        const user = await requireAuth(request, reply);\r\n        if (!user) return;\r\n        const q = request.query as {\r\n            shop_id?: string;\r\n            barber_id?: string;\r\n            min_rating?: string;\r\n            limit?: string;\r\n            offset?: string;\r\n        };\r\n        const reviews = await listProviderReviews({\r\n            shop_id: q.shop_id ?? null,\r\n            barber_id: q.barber_id ?? null,\r\n            min_rating: q.min_rating ? Number(q.min_rating) : undefined,\r\n            limit: q.limit ? Number(q.limit) : 20,\r\n            offset: q.offset ? Number(q.offset) : 0,\r\n        });\r\n        return { reviews };\r\n    });\r\n\r\n    fastify.get('/api/reviews/status/:bookingId', async (request, reply) => {\r\n        const user = await requireAuth(request, reply);\r\n        if (!user) return;\r\n        const { bookingId } = request.params as { bookingId: string };\r\n        try {\r\n            return await getBookingReviewStatus(bookingId, user.id);\r\n        } catch (e: unknown) {\r\n            const msg = e instanceof Error ? e.message : 'Failed to load review status';\r\n            const code = msg === 'Unauthorized' ? 403 : 400;\r\n            return reply.status(code).send({ error: msg });\r\n        }\r\n    });\r\n\r\n    fastify.post<{\r\n        Body: {\r\n            booking_id: string;\r\n            target_type?: string;\r\n            rating: number;\r\n            content?: string;\r\n        };\r\n    }>('/api/reviews', async (request, reply) => {\r\n        const user = await requireAuth(request, reply);\r\n        if (!user) return;\r\n        const body = request.body ?? {};\r\n        const targetType = parseTargetType(body.target_type) ?? 'barber';\r\n        try {\r\n            return await submitReview({\r\n                booking_id: body.booking_id,\r\n                reviewer_id: user.id,\r\n                target_type: targetType,\r\n                rating: Number(body.rating),\r\n                content: body.content,\r\n            });\r\n        } catch (e: unknown) {\r\n            const msg = e instanceof Error ? e.message : 'Failed to submit review';\r\n            return reply.status(400).send({ error: msg });\r\n        }\r\n    });\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\server\\src\\seo\\__tests__\\cityFromLocation.test.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\server\\src\\seo\\cities.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\server\\src\\seo\\cityFromLocation.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\server\\src\\seo\\logic.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\server\\src\\seo\\routes.ts","messages":[{"ruleId":"@typescript-eslint/require-await","severity":1,"message":"Async function 'seoRoutes' has no 'await' expression.","line":4,"column":8,"nodeType":"FunctionDeclaration","messageId":"missingAwait","endLine":4,"endColumn":32,"suggestions":[{"messageId":"removeAsync","fix