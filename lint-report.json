\"Home or Work address\" />\r\n                                                </div>\r\n                                                <p className=\"text-xs text-muted-foreground font-medium ml-1\">Optional ÔÇô used for nearby barbers and directions.</p>\r\n                                            </div>\r\n                                        </div>\r\n                                        <div className=\"pt-6 border-t border-border flex justify-end\">\r\n                                            <Button type=\"submit\" className=\"h-12 px-10 rounded-2xl bg-primary text-primary-foreground font-black transition-all active:scale-95 hover:opacity-95\" disabled={updateProfileMutation.isPending}>\r\n                                                {updateProfileMutation.isPending ? (\r\n                                                    <><Loader className=\"w-4 h-4 mr-2 animate-spin\" /> Syncing Details</>\r\n                                                ) : 'Sync Profile'}\r\n                                            </Button>\r\n                                        </div>\r\n                                    </form>\r\n                                </CardContent>\r\n                            </Card>\r\n                        </TabsContent>\r\n\r\n                        <TabsContent value=\"shipping\" className=\"mt-0\">\r\n                            <Card className=\"border-none shadow-2xl rounded-[32px] bg-card border border-border p-10\">\r\n                                <h2 className=\"text-2xl font-black text-foreground mb-2\">Saved shipping addresses</h2>\r\n                                <p className=\"text-muted-foreground font-medium mb-8\">Manage addresses for marketplace checkout and order delivery.</p>\r\n                                <SavedAddressesManager />\r\n                            </Card>\r\n                        </TabsContent>\r\n\r\n                        <TabsContent value=\"preferences\" className=\"mt-0\">\r\n                            <Card className=\"border-none shadow-2xl rounded-[32px] bg-card border border-border p-10 space-y-8\">\r\n                                <div className=\"flex flex-wrap items-center justify-between gap-4\">\r\n                                    <div>\r\n                                        <h2 className=\"text-2xl font-black text-foreground mb-2\">Alert Preferences</h2>\r\n                                        <p className=\"text-muted-foreground font-medium\">Control how and when you hear from us.</p>\r\n                                    </div>\r\n                                    <Link to={createPageUrl('NotificationSettings')} className=\"text-sm font-semibold text-primary hover:text-primary/80 inline-flex items-center gap-1\">\r\n                                        Full notification settings <ExternalLink className=\"w-3.5 h-3.5\" />\r\n                                    </Link>\r\n                                </div>\r\n\r\n                                <div className=\"space-y-4\">\r\n                                    <AccountNotificationPrefs user={user} />\r\n                                </div>\r\n                            </Card>\r\n                        </TabsContent>\r\n\r\n                        <TabsContent value=\"security\" className=\"mt-0\">\r\n                            <Card className=\"border-none shadow-2xl rounded-[32px] bg-card border border-border p-10 space-y-8\">\r\n                                <div>\r\n                                    <h2 className=\"text-2xl font-black text-foreground mb-2\">Security & Identity</h2>\r\n                                    <p className=\"text-muted-foreground font-medium\">Manage your access and active sessions.</p>\r\n                                </div>\r\n\r\n                                <ClientPaymentMethodsPanel />\r\n\r\n                                <div className=\"p-8 border-2 border-dashed border-border rounded-[32px] text-center\">\r\n                                    <div className=\"w-16 h-16 bg-muted rounded-2xl flex items-center justify-center mx-auto mb-6\">\r\n                                        <Key className=\"w-8 h-8 text-muted-foreground\" />\r\n                                    </div>\r\n                                    <h3 className=\"text-xl font-bold text-foreground mb-2\">Change Password</h3>\r\n                                    <p className=\"text-muted-foreground text-sm max-w-xs mx-auto mb-8 font-medium\">Upgrade your security level with a new robust password.</p>\r\n                                    <Button variant=\"outline\" className=\"h-12 px-8 rounded-2xl border-border font-black hover:bg-muted\">Reset credentials</Button>\r\n                                </div>\r\n                            </Card>\r\n                        </TabsContent>\r\n                </div>\r\n            </div>\r\n            </Tabs>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Jadiss\\OneDrive\\Bureau\\ShopTheBarber\\shop-the-barber\\src\\pages\\AdminAuditLogs.jsx","messages":[{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":26,"column":114,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[1804,1820],"text":"Journaux d&apos;Audit"},"desc":"Replace with `&apos;`."},{"messageId":"replaceWithAlt","data":{"alt":"&lsquo;"},"fix":{"range":[1804,1820],"text":"Journaux d&lsquo;Audit"},"desc":"Replace with `&lsquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#39;"},"fix":{"range":[1804,1820],"text":"Journaux d&#39;Audit"},"desc":"Replace with `&#39;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rsquo;"},"fix":{"range":[1804,1820],"text":"Journaux d&rsquo;Audit"},"desc":"Replace with `&rsquo;`."}]},{"ruleId":"unused-imports