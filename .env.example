# ShopTheBarber — Root env example
# Backend env vars live in server/.env (see server/.env.example).
#
# Auth model (interactive users):
#   - Frontend: Clerk is required — set VITE_CLERK_PUBLISHABLE_KEY below and run the app with .env.local
#     (missing key → Clerk Not Configured screen in App.jsx).
#   - Backend: Set CLERK_SECRET_KEY (+ optional CLERK_PUBLISHABLE_KEY) in server/.env so API routes can
#     verify Clerk session tokens sent as Bearer. Also set JWT_SECRET in production — required for Fastify JWT
#     and legacy /api/auth/* email+password flows; see server/.env.example.
#
VITE_API_URL=
# Clerk (Frontend) — https://dashboard.clerk.com — must match the Clerk project used server-side.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
