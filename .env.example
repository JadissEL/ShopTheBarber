# ShopTheBarber — Root env example
# Backend env vars live in server/.env (see server/.env.example).
#
# Auth: Clerk only — set VITE_CLERK_PUBLISHABLE_KEY below and CLERK_SECRET_KEY in server/.env.
# Database: Neon PostgreSQL via server/.env DATABASE_URL (not configured here).
#
# Production deploy: docs/DEPLOYMENT.md
VITE_API_URL=
# GitHub Actions only (Financial Trust crons) — not used by the Vite app at runtime
# PRODUCTION_API_URL=https://your-api.onrender.com
# Public site origin for SEO (canonical URLs, sitemap, robots). Production: https://shop-the-barber.vercel.app
VITE_SITE_URL=
# Clerk (Frontend) — https://dashboard.clerk.com — must match the Clerk project used server-side.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Mapbox — public token for map tiles in Leaflet (https://account.mapbox.com)
# Use the same Mapbox account as server MAPBOX_ACCESS_TOKEN; restrict by URL in Mapbox dashboard.
VITE_MAPBOX_ACCESS_TOKEN=pk.test_...

# Sentry (Frontend) — same Sentry org, create a React/Vite project for the client DSN.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
# Optional release (git SHA) for source maps / release tracking.
# VITE_SENTRY_RELEASE=

# Feature modules — set to "false" to hide a vertical (nav + route guard). Default: enabled.
# VITE_FEATURE_MARKETPLACE=false
# VITE_FEATURE_CAREERS=false
# VITE_FEATURE_CONTENT=false
# VITE_FEATURE_ENGAGEMENT=false
# VITE_FEATURE_MESSAGING=false
# VITE_FEATURE_PROGRAMS=false
# VITE_FEATURE_SHOP_OPS=false
