# Copy to render.secrets.local.env (gitignored), fill values, then:
#   node scripts/apply-render-env.mjs
#
# Stripe (test mode OK first): https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Upstash Redis (free tier): https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Geocoding — Mapbox recommended: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=
